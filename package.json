{
  "name": "saasguard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "setup": "./scripts/setup.sh",
    "dev": "./scripts/dev.sh",
    "dev:pm2": "pm2 start ecosystem.config.js",
    "dev:logs": "pm2 logs",
    "dev:stop": "pm2 stop all",
    "dev:restart": "pm2 restart all",
    "dev:backend": "npm --prefix apps/backend run start:dev",
    "dev:frontend": "npm --prefix apps/frontend run dev",
    "build": "npm --prefix apps/backend run build && npm --prefix apps/frontend run build",
    "start": "pm2 start ecosystem.config.prod.js",
    "start:logs": "pm2 logs",
    "start:stop": "pm2 stop all",
    "start:restart": "pm2 reload all",
    "start:status": "pm2 status",
    "docker:build": "./scripts/build-docker.sh",
    "docker:push": "./scripts/build-docker.sh --push",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
