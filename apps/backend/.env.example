# Server
PORT=3005
NODE_ENV=development

# Branding
APP_NAME=SaaSGuard
APP_SHORT_NAME=SaaSGuard

# Database (matches docker-compose.yml)
DATABASE_HOST=localhost
DATABASE_PORT=5435
DATABASE_USER=saasguard
DATABASE_PASSWORD=saasguard_dev_2025
DATABASE_NAME=saasguard_dev

# JWT
JWT_SECRET=dev-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=24h

# Admin (auto-seed on first boot if no users exist)
ADMIN_EMAIL=admin@localhost.dev
ADMIN_PASSWORD=admin123456

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=SaaSGuard
SMTP_FROM_EMAIL=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3006

# Metrics
METRICS_INTERVAL_MS=3000

# Alert cooldown (prevent spam)
ALERT_COOLDOWN_MS=300000
